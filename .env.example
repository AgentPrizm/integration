# AgentPrizm API keys are prefixed with ap_
AGENTPRIZM_API_KEY=ap_xxxxxxxxxxxxxxxxxx

# Optional: override for local tests, staging, or future dedicated environments.
AGENTPRIZM_BASE_URL=https://agentprizm.com

# Use containers to isolate customers, environments, agents, and demos.
AGENTPRIZM_CONTAINER=demo-acme
